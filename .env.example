# =============================================================
# Environment variables untuk docker compose
# Salin file ini jadi `.env` lalu isi nilainya:
#   cp .env.example .env
# =============================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=dss_db
POSTGRES_USER=dss_user
POSTGRES_PASSWORD=dss_pass
POSTGRES_PORT=5432

# ---------- Backend (ASP.NET Core) ----------
ASPNETCORE_ENVIRONMENT=Development
BACKEND_PORT=8080

# ---------- Frontend (Nginx) ----------
FRONTEND_PORT=80